# Clerk — use keys from your Clerk dashboard.
# Dashboard: https://dashboard.clerk.com → select application → API Keys
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_your_key_here

# Server-only (Vercel / Node). Required for full Clerk server features; optional for static pages.
# CLERK_SECRET_KEY=sk_your_secret_here

# Unity redirect — URL scheme for returning to the Unity app after auth
NEXT_PUBLIC_UNITY_URL_SCHEME=unity://
