# Clerk — use keys from the instance that serves your app (Frontend API host below).
# Dashboard: https://dashboard.clerk.com → select application → API Keys
#
# DreamForge dev instance (matches Unity OAuth / PKCE):
#   https://destined-sheep-19.clerk.accounts.dev
#
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here

# Server-only (Vercel / Node). Required for full Clerk server features; optional for static pages.
# CLERK_SECRET_KEY=sk_test_your_secret_here

# Unity redirect — URL scheme for returning to the Unity app after auth
NEXT_PUBLIC_UNITY_URL_SCHEME=unity://
